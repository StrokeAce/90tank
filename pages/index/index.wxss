page {
  width: 100vw;
  height: 100vh;
  background: #000;
  margin: 0;
  padding: 0;
}

.game-container {
  width: 100vw;
  height: 100vh;
  background: #000;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.game-canvas {
  width: 100%;
  height: 100%;
  object-fit: contain;
}
