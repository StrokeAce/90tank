.container {
  width: 100%;
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 50rpx;
  color: #ffcc00;
  font-weight: bold;
  letter-spacing: 5rpx;
}

.mode-section, .difficulty-section, .levels-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  color: #aaa;
  margin-bottom: 20rpx;
  display: block;
}

.mode-buttons, .difficulty-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.mode-btn, .diff-btn {
  width: 200rpx;
  height: 80rpx;
  background: linear-gradient(180deg, #3a3a5a 0%, #2a2a4a 100%);
  border: 3rpx solid #5a5a7a;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #888;
  font-size: 32rpx;
  transition: all 0.2s;
}

.mode-btn.active, .diff-btn.active {
  background: linear-gradient(180deg, #5a5a8a 0%, #4a4a6a 100%);
  border-color: #8a8aaa;
  color: #fff;
  box-shadow: 0 0 15rpx rgba(100,100,150,0.5);
}

.diff-btn.diff-easy.active {
  background: linear-gradient(180deg, #4a8a4a 0%, #3a6a3a 100%);
  border-color: #6aaa6a;
}

.diff-btn.diff-medium.active {
  background: linear-gradient(180deg, #8a8a4a 0%, #6a6a3a 100%);
  border-color: #aaaa6a;
}

.diff-btn.diff-hard.active {
  background: linear-gradient(180deg, #8a4a4a 0%, #6a3a3a 100%);
  border-color: #aa6a6a;
}

.levels-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  justify-content: center;
}

.level-btn {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(180deg, #4a4a6a 0%, #3a3a5a 100%);
  border: 3rpx solid #6a6a8a;
  border-radius: 15rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.level-btn:active:not(.locked) {
  transform: scale(0.95);
}

.level-btn.locked {
  background: linear-gradient(180deg, #2a2a3a 0%, #1a1a2a 100%);
  border-color: #4a4a5a;
}

.level-num {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.level-btn.locked .level-num {
  color: #555;
}

.level-lock {
  position: absolute;
  font-size: 30rpx;
}

.info-section {
  margin: 30rpx 0;
}

.info-text {
  font-size: 28rpx;
  color: #888;
}

.back-btn {
  width: 250rpx;
  height: 80rpx;
  background: linear-gradient(180deg, #4a4a6a 0%, #2a2a4a 100%);
  border: 3rpx solid #6a6a8a;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  margin-top: 20rpx;
}

.back-btn:active {
  transform: scale(0.95);
}