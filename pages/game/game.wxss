.game-container {
  width: 100%;
  height: 100vh;
  background: #000;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.game-canvas {
  max-width: 100%;
  max-height: 100%;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.game-hud {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx;
  box-sizing: border-box;
  z-index: 10;
}

.hud-left {
  display: flex;
  gap: 30rpx;
}

.hud-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hud-label {
  font-size: 20rpx;
  color: #888;
}

.hud-value {
  font-size: 28rpx;
  color: #ffcc00;
  font-weight: bold;
}

.pause-btn, .mute-btn {
  width: 80rpx;
  height: 50rpx;
  background: linear-gradient(180deg, #4a4a6a 0%, #2a2a4a 100%);
  border: 2rpx solid #6a6a8a;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.mute-btn {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.controls-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 280rpx;
  pointer-events: none;
  z-index: 20;
}

.joystick-area {
  position: absolute;
  left: 30rpx;
  bottom: 30rpx;
  width: 200rpx;
  height: 200rpx;
  pointer-events: auto;
}

.joystick-base {
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, #3a3a5a 0%, #2a2a4a 100%);
  border: 4rpx solid #5a5a7a;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.joystick-stick {
  width: 80rpx;
  height: 80rpx;
  background: radial-gradient(circle, #6a6a8a 0%, #4a4a6a 100%);
  border: 3rpx solid #8a8aaa;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  transition: transform 0.1s;
}

.joystick-stick.active {
  background: radial-gradient(circle, #8a8aaa 0%, #6a6a8a 100%);
}

.fire-buttons {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  display: flex;
  gap: 20rpx;
  pointer-events: auto;
}

.fire-btn {
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, #8a4a4a 0%, #6a3a3a 100%);
  border: 4rpx solid #aa5a5a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.fire-btn:active {
  background: radial-gradient(circle, #aa5a5a 0%, #8a4a4a 100%);
  transform: scale(0.95);
}

.pause-modal, .game-over-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.pause-modal.show, .game-over-modal.show {
  display: flex;
}

.pause-content, .game-over-content {
  width: 550rpx;
  background: linear-gradient(180deg, #2a2a4a 0%, #1a1a2e 100%);
  border: 3rpx solid #6a6a8a;
  border-radius: 20rpx;
  padding: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pause-title, .game-over-title {
  font-size: 48rpx;
  color: #ffcc00;
  margin-bottom: 40rpx;
  display: block;
  text-align: center;
}

.pause-btns, .game-over-btns {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.pause-btn-item, .game-over-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(180deg, #4a4a6a 0%, #2a2a4a 100%);
  border: 2rpx solid #6a6a8a;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
}

.pause-btn-item:active, .game-over-btn:active {
  transform: scale(0.98);
  background: linear-gradient(180deg, #5a5a7a 0%, #3a3a5a 100%);
}

.level-start-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.9);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.level-start-modal.show {
  display: flex;
}

.level-start-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.level-start-title {
  font-size: 80rpx;
  color: #ffcc00;
  font-weight: bold;
  text-shadow: 0 0 30rpx #ffcc00;
  animation: pulse 1s ease-in-out infinite;
}

.level-start-subtitle {
  font-size: 32rpx;
  color: #aaa;
  margin-top: 20rpx;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}