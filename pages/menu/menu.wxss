.container {
  width: 100vw;
  height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.main-layout {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
  width: 100%;
  padding: 0 60rpx;
  box-sizing: border-box;
}

.left-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.right-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.title {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.title-text {
  font-size: 80rpx;
  font-weight: bold;
  color: #ffcc00;
  text-shadow: 0 0 20px #ffcc00, 0 4px 0 #cc9900;
  letter-spacing: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #888;
  margin-top: 15rpx;
  letter-spacing: 3rpx;
}

.menu {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 30rpx;
  z-index: 10;
}

.menu-item {
  width: 250rpx;
  height: 80rpx;
  background: linear-gradient(180deg, #4a4a6a 0%, #2a2a4a 100%);
  border: 3rpx solid #6a6a8a;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 30rpx;
  letter-spacing: 5rpx;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.5);
  transition: all 0.2s;
}

.menu-item:active {
  transform: scale(0.95);
  background: linear-gradient(180deg, #5a5a7a 0%, #3a3a5a 100%);
}

.tank-icon {
  width: 120rpx;
  height: 120rpx;
  position: relative;
}

.tank-body {
  width: 80rpx;
  height: 80rpx;
  background: #4a7c4a;
  border: 4rpx solid #2a5c2a;
  border-radius: 10rpx;
  position: absolute;
  bottom: 10rpx;
  left: 50%;
  transform: translateX(-50%);
}

.tank-turret {
  width: 12rpx;
  height: 50rpx;
  background: #2a5c2a;
  position: absolute;
  bottom: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 3rpx;
}

.controls-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.preview-label {
  font-size: 20rpx;
  color: #6a6a8a;
  letter-spacing: 2rpx;
}

.help-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.8);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.help-modal.show {
  display: flex;
}

.help-content {
  width: 700rpx;
  max-height: 80vh;
  background: linear-gradient(180deg, #2a2a4a 0%, #1a1a2e 100%);
  border: 3rpx solid #6a6a8a;
  border-radius: 20rpx;
  padding: 40rpx;
  overflow-y: auto;
}

.help-title {
  font-size: 36rpx;
  color: #ffcc00;
  text-align: center;
  margin-bottom: 25rpx;
  display: block;
}

.help-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.help-text text {
  font-size: 22rpx;
  color: #ccc;
  line-height: 1.5;
}

.help-close {
  width: 180rpx;
  height: 60rpx;
  background: linear-gradient(180deg, #4a4a6a 0%, #2a2a4a 100%);
  border: 2rpx solid #6a6a8a;
  border-radius: 10rpx;
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 25rpx auto 0;
}
